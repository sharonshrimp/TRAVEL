                title: "告別洛磯山脈",
                focus: "返程與採購",
                steps: [
                    { time: "08:30", icon: "🍁", title: "紀念品採購", desc: "購買楓糖漿、紀念品。外帶咖啡。" },
                    { time: "09:30", icon: "🚌", title: "啟程返回溫哥華", desc: "沿原路返回。自駕者可順路停翡翠湖 (Emerald Lake)。" },
                    { time: "15:30", icon: "🛣️", title: "繼續車程", desc: "沿途小鎮午餐。" },
                    { time: "20:30", icon: "🍜", title: "抵達溫哥華晚餐", desc: "列治文港式燒臘或日式居酒屋，撫慰旅途疲勞。" }
                ],
                vibe: { nature: 3, city: 2, food: 4, relax: 2 },
                stats: { steps: "4,000", transport: "汽車/巴士 (10hr)" },
                food: [
                    { name: "列治文亞餐", type: "晚餐", desc: "回到亞洲美食天堂，選擇多樣。" }
                ],
                tip: "返回溫哥華時通常會比去程快一點 (下坡多)，但仍需預留充足時間。"
            },
            {
                day: 9,
                date: "6/25",
                city: "北溫哥華",
                title: "免費吊橋秘境",
                focus: "雨林探險",
                steps: [
                    { time: "09:30", icon: "⛴️", title: "搭乘 SeaBus", desc: "海上巴士跨海前往北溫哥華，欣賞海景。" },
                    { time: "10:30", icon: "🌉", title: "林恩峽谷公園", desc: "體驗免費懸索橋，溫帶雨林健行。" },
                    { time: "13:30", icon: "🥣", title: "午餐：Lonsdale Quay", desc: "公眾市場內的海鮮湯與平價攤位。" },
                    { time: "15:00", icon: "☕", title: "碼頭自由活動", desc: "喝咖啡看海，或回住宿午休。" },
                    { time: "18:00", icon: "🥩", title: "晚餐：韓式烤肉", desc: "市區或 Lougheed 附近的韓式料理。" }
                ],
                vibe: { nature: 5, city: 2, food: 3, relax: 4 },
                stats: { steps: "12,000", transport: "船/公車" },
                food: [
                    { name: "Lonsdale Quay Market", type: "午餐", desc: "海鮮濃湯是必點。" },
                    { name: "韓式烤肉", type: "晚餐", desc: "滿足對肉類的渴望。" }
                ],
                tip: "林恩峽谷比卡皮拉諾吊橋更原始且免費，但人也不少，建議上午前往。"
            },
            {
                day: 10,
                date: "6/26",
                city: "溫哥華",
                title: "文化尋根與夜市",
                focus: "文化與狂歡",
                steps: [
                    { time: "10:00", icon: "🗿", title: "UBC 人類學博物館", desc: "或伊莉莎白王后公園。欣賞原住民圖騰與花園。" },
                    { time: "13:00", icon: "🥗", title: "午餐：輕食", desc: "校園或公園附近。" },
                    { time: "14:30", icon: "🧳", title: "打包行李", desc: "整理戰利品，最後休息。" },
                    { time: "18:30", icon: "🏮", title: "列治文夜市", desc: "北美最大夜市 (僅週末)。烤魷魚、旋風土豆、肉串。" }
                ],
                vibe: { nature: 2, city: 4, food: 5, relax: 3 },
                stats: { steps: "8,000", transport: "捷運/步行" },
                food: [
                    { name: "列治文夜市", type: "晚餐", desc: "狂掃街頭小吃：烤魷魚、章魚燒。" }
                ],
                tip: "列治文夜市入場需要門票，建議準備現金 (Cash is King)。"
            },
            {
                day: 11,
                date: "6/27",
                city: "溫哥華",
                title: "滿載而歸",
                focus: "購物與離境",
                steps: [
                    { time: "09:00", icon: "🛍️", title: "最後採購", desc: "Robson St 或機場 Outlet。" },
                    { time: "11:00", icon: "✈️", title: "前往機場", desc: "搭乘 Canada Line 抵達 YVR。" },
                    { time: "End", icon: "👋", title: "旅程結束", desc: "帶著美好的回憶回家！" }
                ],
                vibe: { nature: 1, city: 4, food: 2, relax: 2 },
                stats: { steps: "5,000", transport: "捷運/飛機" },
                food: [],
                tip: "機場 Outlet 離機場非常近，搭捷運只需兩站，適合最後衝刺。"
            }
        ];

        const packingItems = [
            "防風防水夾克 (洛磯山脈必備)",
            "舒適防水健行鞋",
            "洋蔥式穿搭衣物 (短袖+長袖+外套)",
            "太陽眼鏡 & 帽子",
            "高係數防曬乳",
            "泳衣 (班夫溫泉用)",
            "個人藥品 & 暈車藥",
            "牙刷牙膏 (環保旅宿可能不提供)",
            "空水瓶 (可生飲自來水)",
            "Compass Card (抵達購買)",
            "防熊噴霧 (當地買，不能帶上飛機)"
        ];

        // --- STATE MANAGEMENT ---
        let activeDay = 1;
        let vibeChartInstance = null;

        // --- DOM ELEMENTS ---
        const dayNavContainer = document.getElementById('day-nav-container');
        const timelineContent = document.getElementById('timeline-content');
        const timelineTitle = document.getElementById('timeline-title');
        const timelineDate = document.getElementById('timeline-date');
        const currentCityDisplay = document.getElementById('current-city-display');
        const dayFocusDisplay = document.getElementById('day-focus-display');
        const foodHighlights = document.getElementById('food-highlights');
        const dailyTip = document.getElementById('daily-tip');
        const stepCount = document.getElementById('step-count');
        const transportMode = document.getElementById('transport-mode');
        const packingListContainer = document.getElementById('packing-list');

        // --- INITIALIZATION ---
        function init() {
            renderDayNav();
            renderPackingList();
            loadDay(1); // Load Day 1 by default
        }

        // --- RENDER FUNCTIONS ---

        // 1. Render Day Navigation Buttons
        function renderDayNav() {
            dayNavContainer.innerHTML = '';
            tripData.forEach(day => {
                const btn = document.createElement('button');
                btn.className = `px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-colors duration-200 border ${activeDay === day.day ? 'active-day-btn' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'}`;
                btn.textContent = `Day ${day.day} (${day.date})`;
                btn.onclick = () => loadDay(day.day);
                dayNavContainer.appendChild(btn);
            });
        }

        // 2. Render Packing List
        function renderPackingList() {
            packingListContainer.innerHTML = '';
            packingItems.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = 'flex items-center gap-3 p-2 hover:bg-slate-50 rounded transition';
                div.innerHTML = `
                    <input type="checkbox" id="pack-${index}" class="w-4 h-4 text-teal-600 rounded border-slate-300 focus:ring-teal-500 cursor-pointer">
                    <label for="pack-${index}" class="text-slate-700 text-sm cursor-pointer select-none">${item}</label>
                `;
                packingListContainer.appendChild(div);
            });
        }

        // 3. Main Load Function for a specific Day
        function loadDay(dayIndex) {
            activeDay = dayIndex;
            const data = tripData.find(d => d.day === dayIndex);
            
            // Update UI Texts
            timelineTitle.innerHTML = `<span>📅</span> 第${data.day}天：${data.title}`;
            timelineDate.textContent = data.date;
            currentCityDisplay.textContent = data.city;
            dayFocusDisplay.textContent = data.focus;
            dailyTip.textContent = data.tip;
            stepCount.textContent = data.stats.steps;
            transportMode.textContent = data.stats.transport;

            // Update Nav Styling
            renderDayNav();

            // Render Timeline
            renderTimeline(data.steps);

            // Render Food
            renderFood(data.food);

            // Update Chart
            updateVibeChart(data.vibe);
        }

        function renderTimeline(steps) {
            timelineContent.innerHTML = '<div class="timeline-line"></div>'; // Reset and add line
            
            steps.forEach((step, index) => {
                const item = document.createElement('div');
                item.className = 'relative z-10 mb-8 pl-8 group';
                item.innerHTML = `
                    <div class="absolute left-2 top-0 w-8 h-8 -ml-4 flex items-center justify-center rounded-full bg-white border-2 border-teal-500 text-lg shadow-sm group-hover:scale-110 transition-transform">
                        ${step.icon}
                    </div>
                    <div class="bg-white p-4 rounded-lg border border-slate-100 shadow-sm hover:shadow-md transition-shadow">
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-1">
                            <h4 class="font-bold text-slate-800">${step.title}</h4>
                            <span class="text-xs font-mono text-slate-500 bg-slate-100 px-2 py-1 rounded w-fit mt-1 sm:mt-0">${step.time}</span>
                        </div>
                        <p class="text-sm text-slate-600">${step.desc}</p>
                    </div>
                `;
                timelineContent.appendChild(item);
            });
        }

        function renderFood(foods) {
            foodHighlights.innerHTML = '';
            if (foods.length === 0) {
                foodHighlights.innerHTML = '<p class="text-sm text-slate-400 italic">今日無特定推薦，可自由探索。</p>';
                return;
            }
            foods.forEach(food => {
                const item = document.createElement('div');
                item.className = 'flex items-start gap-3 p-3 bg-orange-50 rounded-lg border border-orange-100';
                item.innerHTML = `
                    <div class="mt-1 text-orange-500">🍴</div>
                    <div>
                        <div class="font-bold text-slate-800 text-sm">${food.name} <span class="text-xs font-normal text-orange-600 ml-1">(${food.type})</span></div>
                        <p class="text-xs text-slate-600 mt-1">${food.desc}</p>
                    </div>
                `;
                foodHighlights.appendChild(item);
            });
        }

        // 4. Chart.js Visualization
        function updateVibeChart(vibeData) {
            const ctx = document.getElementById('vibeChart').getContext('2d');
            
            const dataValues = [vibeData.nature, vibeData.city, vibeData.food, vibeData.relax];
            
            if (vibeChartInstance) {
                vibeChartInstance.data.datasets[0].data = dataValues;
                vibeChartInstance.update();
            } else {
                vibeChartInstance = new Chart(ctx, {
                    type: 'radar',
                    data: {
                        labels: ['戶外/自然', '城市/文化', '美食/小吃', '放鬆/休閒'],
                        datasets: [{
                            label: '體驗強度',
                            data: dataValues,
                            backgroundColor: 'rgba(20, 184, 166, 0.2)', // Teal 500
                            borderColor: 'rgba(13, 148, 136, 1)', // Teal 600
                            pointBackgroundColor: 'rgba(245, 158, 11, 1)', // Amber 500
                            borderWidth: 2,
                            pointRadius: 3
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            r: {
                                min: 0,
                                max: 5,
                                ticks: {
                                    stepSize: 1,
                                    display: false 
                                },
                                pointLabels: {
                                    font: {
                                        size: 12,
                                        family: "'Noto Sans TC', sans-serif"
                                    },
                                    color: '#475569'
                                }
                            }
                        },
                        plugins: {
                            legend: {
                                display: false
                            }
                        }
                    }
                });
            }
        }

        // Initialize App
        init();

    </script>
</body>
</html>
